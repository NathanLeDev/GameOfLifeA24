<Window x:Class="GameOfLifeUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Game of Life" Height="720" Width="980">
    <DockPanel>
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8">
            <Button Content="Start/Stop" Width="90" Margin="0,0,8,0" Click="Start"/>
            <Button Content="Next" Width="70" Margin="0,0,8,0" Click="Timer_Tick"/>
            <Button Content="Clear" Width="70" Margin="0,0,8,0" Click="ClearState"/>
            <TextBlock Text="Initial State:" VerticalAlignment="Center" Margin="10,0,6,0"/>
            <ComboBox x:Name="InitialStatesCombo" Width="200" SelectionChanged="InitialStateChange"/>
            <Button Content="Save" Width="70" Margin="8,0,0,0" Click="SaveInitialState"/>
            <Button Content="Delete" Width="70" Margin="8,0,0,0" Click="DeleteInitState"/>
        </StackPanel>

        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <UniformGrid x:Name="GridHost" Margin="8"/>
        </ScrollViewer>
    </DockPanel>
</Window>
